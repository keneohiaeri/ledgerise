{
  "name": "@ledgerise/core-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./src/postgres.ts",
      "import": "./dist/postgres.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/engine.test.mjs"
  },
  "dependencies": {
    "@ledgerise/canonical-types": "0.1.0",
    "@ledgerise/core-mapping": "0.1.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
