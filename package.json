{
  "name": "ledgerise",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable double-entry automation for payment operators.",
  "workspaces": [
    "apps/*",
    "core/*",
    "packages/*",
    "adapters/inbound/*",
    "adapters/outbound/*"
  ],
  "scripts": {
    "start": "node apps/api/dist/index.js",
    "start:web": "npm start -w apps/web",
    "start:worker": "npm start -w apps/worker",
    "dev": "npm run dev:api & npm run dev:web & npm run dev:worker & wait",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify:postgres": "node scripts/verify-postgres-ingestion.mjs",
    "verify:generic-webhook": "node scripts/verify-generic-webhook.mjs",
    "verify:generic-csv": "node scripts/verify-generic-csv.mjs",
    "verify:generic-poll": "node scripts/verify-generic-poll.mjs",
    "verify:poll-cursor-safety": "node scripts/verify-poll-cursor-safety.mjs",
    "verify:poll-scheduler": "node scripts/verify-poll-scheduler.mjs",
    "verify:access-management": "node scripts/verify-access-management.mjs",
    "verify:mapping": "node scripts/verify-mapping.mjs",
    "verify:engine": "node scripts/verify-engine.mjs",
    "verify:posting": "node scripts/verify-posting.mjs",
    "verify:outbound-csv": "node scripts/verify-outbound-csv.mjs",
    "verify:posting-file-exchange": "node scripts/verify-posting-file-exchange.mjs",
    "verify:zoho-books": "node scripts/verify-zoho-books.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
