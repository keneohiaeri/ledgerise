# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/ledgerise

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required in production. HMAC secret for session tokens.
# Generate: openssl rand -base64 32
AUTH_TOKEN_SECRET=ledgerise-local-development-secret

# Required in production. AES-256-GCM key for adapter credential encryption.
# Generate: openssl rand -hex 32
LEDGERISE_CREDENTIALS_KEY=

# ── Bootstrap admin ───────────────────────────────────────────────────────────
# Required on first startup only. Creates the initial admin user.
# Remove after first login and password change.
LEDGERISE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
LEDGERISE_BOOTSTRAP_ADMIN_PASSWORD=changeme
LEDGERISE_BOOTSTRAP_ADMIN_NAME=Ledgerise Admin

# ── Engine ────────────────────────────────────────────────────────────────────
ENGINE_SCHEDULE_CRON=0 * * * *
ENGINE_BATCH_SIZE=500
SUSPENSE_ACCOUNT_CODE=199999

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
DEFAULT_OPERATOR_SLUG=local-operator

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=3001
# Required at frontend build time. Set to the public URL of the API.
VITE_API_BASE_URL=http://localhost:3000
